# ------------------------------------------------
# Dependencies (ไฟล์ไลบรารีขนาดใหญ่ ห้ามเอาขึ้นเด็ดขาด)
# ------------------------------------------------
node_modules/
.pnp
.pnp.js
# ------------------------------------------------
# Build Output (ไฟล์ที่ได้จากการสั่ง npm run build)
# ------------------------------------------------
dist/
build/

# ------------------------------------------------
# Environment Variables (ไฟล์เก็บ Key ความลับ)
# ------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ------------------------------------------------
# Logs (ไฟล์แจ้งเตือน Error ไม่จำเป็นต้องเก็บ)
# ------------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ------------------------------------------------
# OS Files (ไฟล์ขยะของระบบปฏิบัติการ)
# ------------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ------------------------------------------------
# Editor Directories (การตั้งค่าส่วนตัวของโปรแกรมเขียนโค้ด)
# ------------------------------------------------
.vscode/
.idea/
*.suo
*.ntvs
*.njsproj
*.sln
*.sw?

# ------------------------------------------------
# Testing
# ------------------------------------------------
coverage/
# Ignore video files
*.mp4
*.mov

# ------------------------------------------------
# Media Files (ไฟล์สื่อ - ใช้บน Cloud แทน)
# ------------------------------------------------
public/images/
public/videos/